# ── Anthropic (Claude API for the Ask tab) ─────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=<anthropic-api-key>

# ── Google OAuth (Calendar read/write) ─────────────
# Get from: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://YOUR-VERCEL-URL/api/auth/google/callback
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=<google-client-secret>
GOOGLE_REDIRECT_URI=https://your-vercel-url.vercel.app/api/auth/google-callback

# ── Upstash Redis (token + push subscription storage) ──
# One-click create at: vercel.com dashboard → Storage → Create Database → Upstash KV
# These two are auto-injected by Vercel after you connect the database.
KV_REST_API_URL=https://...upstash.io
KV_REST_API_TOKEN=...

# ── Supabase (conversation history + practice logs) ─────
# Project Settings → Data API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=
# Project Settings → API Keys. Server-side only; never expose in public/js.
SUPABASE_SERVICE_ROLE_KEY=

# ── Web Push (VAPID) ──────────────────────────────
# Generate with: npm run gen:vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:rayanthony@xqsitor.org

# ── Single-user auth ──────────────────────────────
# Long random string. The app is gated to one user (you).
# Generate: openssl rand -hex 32
USER_SESSION_SECRET=

# Your timezone for cron-triggered notifications
USER_TIMEZONE=America/New_York
